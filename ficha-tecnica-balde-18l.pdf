<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<script src="./support.js"></script>
</head>
<body>
<x-dc>

<helmet>
  <title>Ficha Técnica — Balde Metálico 18L Tampa Garra</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.383.0/dist/umd/lucide.min.js"></script>
  <style>
    body { margin:0; font-family:'Plus Jakarta Sans', system-ui, sans-serif; }
    table { border-collapse:collapse; width:100%; }
    th, td { text-align:left; vertical-align:top; }
    .lc { width:16px; height:16px; stroke:currentColor; }
  </style>
</helmet>

<style>doc-page:not(:defined){visibility:hidden}</style>
<x-import component-from-global-scope="doc-page" from="./doc-page.js" size="a4" margin="0" hint-size="100%,100%">

  <div style="padding:0 0 20px;">

    <!-- Header band -->
    <div style="background:#0F1115; padding:36px 44px 28px; display:flex; align-items:center; justify-content:space-between; gap:20px;">
      <div>
        <div style="display:inline-flex; align-items:center; gap:8px; background:rgba(37,99,235,0.15); border:1px solid rgba(96,165,250,0.35); color:#60A5FA; font-size:10px; font-weight:800; letter-spacing:2px; text-transform:uppercase; padding:6px 12px; border-radius:9999px; margin-bottom:14px;">
          <span style="width:6px; height:6px; border-radius:50%; background:#10B981;"></span> Especificação Técnica
        </div>
        <h1 style="font-size:22px; font-weight:800; letter-spacing:-0.5px; color:#fff; margin:0 0 6px; line-height:1.25;">Balde Metálico 18 Litros<br>Tampa Garra (Aranha)</h1>
        <p style="font-size:12.5px; color:#8A93A8; margin:0; max-width:420px; line-height:1.6;">Aço, fechamento tipo garra com lacre de segurança. Não possui propriedade atóxica — não indicado para uso alimentício.</p>
      </div>
      <img src="assets/logo-nastripack.png" alt="Nastripack" style="width:52px; height:52px; border-radius:50%; flex-shrink:0; object-fit:cover;">
    </div>

    <div style="padding:28px 44px 0;">

      <!-- Dimension cards -->
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:14px; margin-bottom:30px;">
        <div style="border:1px solid #E5E7EB; border-radius:12px; padding:16px 18px; background:#FAFAFB;">
          <div style="display:flex; align-items:center; gap:8px; margin-bottom:8px; color:#2563EB;"><i data-lucide="ruler" class="lc"></i><span style="font-size:10px; font-weight:800; letter-spacing:1.2px; text-transform:uppercase; color:#6B7280;">Diâmetro topo / base</span></div>
          <div style="font-size:16px; font-weight:800; color:#111827;">Ø 29,7 / Ø 27,5 cm</div>
        </div>
        <div style="border:1px solid #E5E7EB; border-radius:12px; padding:16px 18px; background:#FAFAFB;">
          <div style="display:flex; align-items:center; gap:8px; margin-bottom:8px; color:#2563EB;"><i data-lucide="move-vertical" class="lc"></i><span style="font-size:10px; font-weight:800; letter-spacing:1.2px; text-transform:uppercase; color:#6B7280;">Altura</span></div>
          <div style="font-size:16px; font-weight:800; color:#111827;">33 cm</div>
        </div>
        <div style="border:1px solid #E5E7EB; border-radius:12px; padding:16px 18px; background:#FAFAFB;">
          <div style="display:flex; align-items:center; gap:8px; margin-bottom:8px; color:#2563EB;"><i data-lucide="weight" class="lc"></i><span style="font-size:10px; font-weight:800; letter-spacing:1.2px; text-transform:uppercase; color:#6B7280;">Peso vazio</span></div>
          <div style="font-size:16px; font-weight:800; color:#111827;">1.360 g ± 30 g</div>
        </div>
      </div>

      <!-- Requirements table -->
      <div style="display:flex; align-items:center; gap:8px; margin-bottom:14px;">
        <i data-lucide="clipboard-check" class="lc" style="color:#2563EB;"></i>
        <h2 style="font-size:13px; font-weight:800; color:#111827; text-transform:uppercase; letter-spacing:1.2px; margin:0;">Requisitos e padrões técnicos</h2>
      </div>

      <table style="font-size:12.5px; border:1px solid #E5E7EB; border-radius:12px; overflow:hidden;">
        <thead>
          <tr style="background:#0F1115;">
            <th style="padding:10px 16px; font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:1px; color:#fff; width:40%;">Item</th>
            <th style="padding:10px 16px; font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:1px; color:#fff;">Requisito</th>
          </tr>
        </thead>
        <tbody>
          <tr style="background:#FAFAFB;">
            <td style="padding:11px 16px; font-weight:700; color:#111827; border-bottom:1px solid #E5E7EB;">Superfície interna e externa (tampa e corpo)</td>
            <td style="padding:11px 16px; color:#4B5563; border-bottom:1px solid #E5E7EB;">Lisa, redonda, sem ferrugem, sem riscos e sem deformação</td>
          </tr>
          <tr>
            <td style="padding:11px 16px; font-weight:700; color:#111827; border-bottom:1px solid #E5E7EB;">Limpeza da superfície interna/externa</td>
            <td style="padding:11px 16px; color:#4B5563; border-bottom:1px solid #E5E7EB;">Sem inclusões, sem graxa e/ou sujeira</td>
          </tr>
          <tr style="background:#FAFAFB;">
